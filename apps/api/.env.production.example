# ============================================================
# FinWallet — Environment Variables PRODUCTION TEMPLATE
# Sao chép file này thành .env.production và điền giá trị thực
# ============================================================

# ── App ────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
APP_NAME=FinWallet API

# ── Frontend URL (thay bằng domain Vercel của bạn) ─────────
FRONTEND_URL=https://finwallet.vercel.app
NEXT_PUBLIC_API_URL=https://finwallet-api.railway.app/api/v1
NEXT_PUBLIC_WS_URL=https://finwallet-api.railway.app

# ── Database Cloud (Railway / Supabase) ────────────────────
# Railway: Lấy từ Dashboard > Postgres > Connect > Connection String
# Supabase: Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres:PASSWORD@HOSTNAME:PORT/finwallet_db?schema=public

# Biến riêng cho docker-compose.prod.yml
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=finwallet_db

# ── Redis ──────────────────────────────────────────────────
# Railway: Lấy từ Dashboard > Redis > Connect
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── JWT (BẮT BUỘC đổi — min 32 ký tự) ────────────────────
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_JWT_SECRET_PRODUCTION
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=CHANGE_ME_MIN_32_CHARS_REFRESH_SECRET_PRODUCTION
JWT_REFRESH_EXPIRES=7d

# ── Security ───────────────────────────────────────────────
BCRYPT_ROUNDS=12
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── AI — Google Gemini ─────────────────────────────────────
# Lấy tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── Storage — Cloudinary ───────────────────────────────────
# Lấy tại: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ── Email SMTP (Gmail App Password) ───────────────────────
# Hướng dẫn: Google Account > Security > 2FA > App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM="FinWallet <your-gmail@gmail.com>"

# ── Google OAuth 2.0 ──────────────────────────────────────
# Tạo tại: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs: https://finwallet-api.railway.app/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://finwallet-api.railway.app/api/v1/auth/google/callback

# ── PayOS (tùy chọn) ──────────────────────────────────────
# Đăng ký tại: https://payos.vn
PAYOS_CLIENT_ID=your-payos-client-id
PAYOS_API_KEY=your-payos-api-key
PAYOS_CHECKSUM_KEY=your-payos-checksum-key
